# OPTIONNEL : Override d'URL XLSX pour la source officielle
# Par défaut, le système détecte automatiquement le fichier le plus récent
# PRIX_ESSENCE_XLSX_URL=https://regieessencequebec.ca/data/stations-*.xlsx

# OPTIONNEL : Fallback si la détection automatique échoue
# PRIX_ESSENCE_XLSX_URL_FALLBACK=https://regieessencequebec.ca/data/stations-fallback.xlsx

# OPTIONNEL : Secret pour l'endpoint POST /api/prix-essence/refresh
# Si défini, les requêtes doivent inclure: Authorization: Bearer YOUR_SECRET
PRIX_ESSENCE_REFRESH_SECRET=your-secret-token-here

# OPTIONNEL : API Key Google Maps (pour migration future)
# GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Configuration Cloudflare Workers KV (pour le binding)
# À configurer dans wrangler.toml avec le binding PRIX_ESSENCE_KV
