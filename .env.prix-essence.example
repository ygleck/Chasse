# Variables d'environnement - Prix Essence Module

# OPTIONNEL : Override d'URL XLSX pour la source officielle
# Par défaut, le système détecte automatiquement le fichier le plus récent depuis regieessencequebec.ca
# PRIX_ESSENCE_XLSX_URL=https://regieessencequebec.ca/data/stations-20260404015005.xlsx

# OPTIONNEL : Fallback si la détection automatique échoue
# PRIX_ESSENCE_XLSX_URL_FALLBACK=https://regieessencequebec.ca/data/stations-20260404015005.xlsx

# OPTIONNEL : Secret pour l'endpoint POST /api/prix-essence/refresh
# Si défini, les requêtes de rafraîchissement doivent inclure: Authorization: Bearer YOUR_SECRET
PRIX_ESSENCE_REFRESH_SECRET=your-secret-token-here

# OPTIONNEL : API Key Google Maps (si vous voulez migrer vers Google Maps plus tard)
# GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# OPTIONNEL : Nominatim custom (si vous avez une instance privée)
# NOMINATIM_URL=https://nominatim.example.com

# Configuration Cloudflare Workers KV
# À configurer dans wrangler.toml avec le binding PRIX_ESSENCE_KV
# Voir documentation: https://developers.cloudflare.com/workers/runtime-apis/kv/
